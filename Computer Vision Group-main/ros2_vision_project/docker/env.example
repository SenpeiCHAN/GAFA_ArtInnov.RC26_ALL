# YOLOv5/YOLOv8-D435i Docker环境变量配置
# 复制此文件为 .env 并根据需要修改

# ===== 显示配置 =====
# X11显示变量（通常不需要修改）
DISPLAY=:0

# ===== GPU配置 =====
# NVIDIA可见设备（all表示所有GPU，或指定设备号如0,1）
NVIDIA_VISIBLE_DEVICES=all

# NVIDIA驱动能力
NVIDIA_DRIVER_CAPABILITIES=all

# ===== 模型配置 =====
# YOLOv8模型路径（相对于/workspace）
MODEL_PATH=yolov8n.pt

# 置信度阈值
CONFIDENCE_THRESHOLD=0.5

# IoU阈值
IOU_THRESHOLD=0.45

# 推理设备（cuda或cpu）
INFERENCE_DEVICE=cuda

# ===== 相机配置 =====
# RealSense分辨率
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# 深度对齐
ALIGN_DEPTH=true

# ===== 应用配置 =====
# 是否发布可视化结果
PUBLISH_VISUALIZATION=true

# 深度采样点数
DEPTH_SAMPLE_POINTS=24

# ===== 资源限制 =====
# CPU核心数限制（留空表示不限制）
CPU_LIMIT=

# 内存限制（例如：8G）
MEMORY_LIMIT=

# ===== 网络配置 =====
# Web服务端口（如果启用）
WEB_PORT=8080

# API端口
API_PORT=5000

# ===== 日志配置 =====
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/workspace/logs/detection.log

# ===== 数据保存 =====
# 是否保存检测结果
SAVE_RESULTS=false

# 结果保存目录
RESULTS_DIR=/workspace/runs

# 是否保存视频
SAVE_VIDEO=false

# 视频保存路径
VIDEO_OUTPUT_PATH=/workspace/runs/output.avi

# ===== 开发配置 =====
# Python缓冲模式（0表示无缓冲）
PYTHONUNBUFFERED=1

# 是否启用调试模式
DEBUG_MODE=false

# ===== 时区配置 =====
TZ=Asia/Shanghai

# ===== 可选：PyTorch配置 =====
# CUDA设备顺序
CUDA_DEVICE_ORDER=PCI_BUS_ID

# 是否启用CUDNN基准测试
CUDNN_BENCHMARK=true

# 是否启用CUDNN确定性
CUDNN_DETERMINISTIC=false

# ===== 可选：OpenCV配置 =====
# 禁用MIT-SHM X扩展（解决某些GUI问题）
QT_X11_NO_MITSHM=1

# ===== 可选：Matplotlib配置 =====
# Matplotlib后端
MPLBACKEND=Agg

# ===== 说明 =====
# 1. 复制此文件为 .env
# 2. 根据需要修改配置项
# 3. Docker Compose会自动读取.env文件
# 4. 留空的变量将使用默认值
